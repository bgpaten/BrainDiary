# Local Brain Engine Worker
# Salin ke frontend/scripts/brain-worker.env lalu isi nilai lokal.
# File ini hanya untuk terminal lokal. Jangan dipakai di browser.

# Supabase project. SUPABASE_URL boleh kosong jika VITE_SUPABASE_URL sudah ada di frontend/.env.
# SUPABASE_URL=https://your-project.supabase.co

# Pilih salah satu mode Supabase:
#
# Mode A - service role lokal. Paling sederhana untuk dev, tapi simpan hanya lokal.
# Ambil dari Supabase Dashboard -> Project Settings -> API -> service_role.
# SUPABASE_SERVICE_ROLE_KEY=YOUR_SERVICE_ROLE_KEY
#
# Mode B - login user biasa. RLS tetap berlaku, worker hanya memproses data user ini.
# SUPABASE_USER_EMAIL=you@example.com
# SUPABASE_USER_PASSWORD=your-password
#
# Mode C - access token user dari sesi Supabase.
# SUPABASE_ACCESS_TOKEN=USER_JWT_ACCESS_TOKEN

# Provider default: official Claude Code CLI lokal.
# Pastikan command `claude` sudah login/terkonfigurasi di terminal kamu.
LLM_PROVIDER=claude-code
CLAUDE_CODE_COMMAND=claude
CLAUDE_CODE_BARE=true
CLAUDE_CODE_API_KEY_HELPER=true
CLAUDE_CODE_TIMEOUT_MS=180000

# Jika Claude Code memakai FreeModel config, letakkan env ini di shell kamu
# atau di file ini. Request tetap berasal dari official Claude Code client lokal.
# ANTHROPIC_API_KEY=YOUR_FREEMODEL_KEY
# ANTHROPIC_BASE_URL=https://cc.freemodel.dev
# CLAUDE_CODE_DISABLE_NONESSENTIAL_TRAFFIC=1

# Alternatif provider API resmi:
# LLM_PROVIDER=anthropic
# ANTHROPIC_API_KEY=YOUR_ANTHROPIC_KEY
# ANTHROPIC_BASE_URL=https://api.anthropic.com
# ANTHROPIC_MODEL=claude-sonnet-4-20250514

# Alternatif OpenAI-compatible:
# LLM_PROVIDER=openai
# LLM_API_KEY=YOUR_KEY
# LLM_BASE_URL=https://provider.example.com
# LLM_MODEL=model-name

# Alternatif local Ollama:
# LLM_PROVIDER=ollama
# OLLAMA_BASE_URL=http://127.0.0.1:11434
# OLLAMA_MODEL=qwen2.5:7b

# Brain Chat MVP (Agent Reader)
# Jika kosong, brain-chat reuse provider LLM_* / ANTHROPIC_* / OLLAMA_* di atas.
# BRAIN_CHAT_PROVIDER=claude-code
# BRAIN_CHAT_MODEL=model-name
# BRAIN_CHAT_BASE_URL=https://provider.example.com
# BRAIN_CHAT_API_KEY=YOUR_KEY
BRAIN_CHAT_MAX_CONTEXT_NODES=12
BRAIN_CHAT_MAX_CONTEXT_EDGES=20
BRAIN_CHAT_MAX_RAW_ENTRIES=5
BRAIN_CHAT_MAX_AGENT_MEMORIES=10

# Timeline Intelligence + Brain Digest
# Jika kosong, brain-digest reuse BRAIN_CHAT_* atau LLM_* provider di atas.
# Set BRAIN_DIGEST_PROVIDER=disabled untuk memakai fallback deterministic tanpa LLM.
# BRAIN_DIGEST_PROVIDER=claude-code
# BRAIN_DIGEST_MODEL=model-name
# BRAIN_DIGEST_API_KEY=YOUR_KEY
# BRAIN_DIGEST_BASE_URL=https://provider.example.com
BRAIN_DIGEST_OUTPUT_OBSIDIAN=true
BRAIN_DIGEST_LIMIT_RAW_ENTRIES=50
BRAIN_DIGEST_LIMIT_NODES=50
BRAIN_DIGEST_LIMIT_EDGES=100
BRAIN_DIGEST_LIMIT_MEMORIES=50

# Brain Evaluation / Memory Accuracy Test
# Evaluator lokal read-only untuk mengukur Brain Chat + Persona Layer.
# Jika BRAIN_EVAL_USE_LLM_JUDGE=false, scoring memakai deterministic checks saja.
# Jika provider kosong/disabled, judge LLM tidak dipanggil.
BRAIN_EVAL_PROVIDER=disabled
# BRAIN_EVAL_PROVIDER=claude-code
# BRAIN_EVAL_MODEL=model-name
# BRAIN_EVAL_API_KEY=YOUR_KEY
# BRAIN_EVAL_BASE_URL=https://provider.example.com
BRAIN_EVAL_USE_LLM_JUDGE=false
BRAIN_EVAL_MAX_CASES=25
BRAIN_EVAL_OUTPUT_OBSIDIAN=true
BRAIN_EVAL_FAIL_ON_LOW_SCORE=false
BRAIN_EVAL_MIN_PASS_SCORE=0.7

# Daily Brain Routine + Stabilization
# Orchestrator lokal yang memanggil command existing secara berurutan.
BRAIN_ROUTINE_ENABLED=true
BRAIN_ROUTINE_DEFAULT_LIMIT=5
BRAIN_ROUTINE_RUN_EVAL=true
BRAIN_ROUTINE_RUN_ATTACHMENTS=true
BRAIN_ROUTINE_RUN_SYNC=true
BRAIN_ROUTINE_RUN_CHAT_IMPORT=false
BRAIN_ROUTINE_RUN_CONFLICTS=false
BRAIN_ROUTINE_RUN_SELF_CLONE_EVAL=false
BRAIN_ROUTINE_RUN_SIMILARITY=false
BRAIN_ROUTINE_RUN_DRIFT_AUDIT=false
BRAIN_ROUTINE_RUN_REFLECTION=false
BRAIN_ROUTINE_OUTPUT_OBSIDIAN=true
BRAIN_ROUTINE_EVAL_MIN_SCORE=0.7
BRAIN_ROUTINE_MAX_HALLUCINATION_RISK=0.3
BRAIN_ROUTINE_WATCH_INTERVAL_MS=21600000

# Brain Backup, Export & Recovery
BRAIN_BACKUP_ENABLED=true
BRAIN_BACKUP_DIR=../backups
BRAIN_BACKUP_INCLUDE_VAULT=true
BRAIN_BACKUP_INCLUDE_ENV=false
BRAIN_BACKUP_COMPRESS=false
BRAIN_BACKUP_MAX_HISTORY=20
BRAIN_RESTORE_REQUIRE_CONFIRM=true

# Persona Layer + Self-Clone Chat
PERSONA_BUILDER_ENABLED=true
PERSONA_PROFILE_OUTPUT_OBSIDIAN=true
PERSONA_PROFILE_MIN_ENTRIES=5
PERSONA_PROFILE_MAX_RAW_ENTRIES=50
PERSONA_PROFILE_MAX_MEMORIES=100
PERSONA_PROFILE_MAX_REPORTS=10
# Default false: persona-builder tidak menulis memory otomatis.
PERSONA_PROFILE_WRITE_MEMORY=false

# Identity Fidelity Engine
# Evidence-bound identity model for Personal Entity OS.
# Jika kosong, identity-fidelity reuse BRAIN_CHAT_*, BRAIN_DIGEST_*, atau LLM_* provider.
IDENTITY_FIDELITY_ENABLED=true
IDENTITY_PROVIDER=
IDENTITY_MODEL=
IDENTITY_API_KEY=
IDENTITY_BASE_URL=
IDENTITY_USE_LLM=true
IDENTITY_MIN_CONFIDENCE=0.45
IDENTITY_CORE_CONFIDENCE=0.85
IDENTITY_OUTPUT_OBSIDIAN=true
IDENTITY_MAX_RAW_ENTRIES=100
IDENTITY_MAX_MEMORIES=100
IDENTITY_MAX_REPORTS=20
IDENTITY_MAX_NODES=200

# Communication Style Model
# Evidence-bound style model for greetings, prompt requests, correction, and technical answers.
# Jika kosong, communication-style reuse IDENTITY_*, BRAIN_CHAT_*, atau LLM_* provider.
COMMUNICATION_STYLE_ENABLED=true
COMMUNICATION_PROVIDER=
COMMUNICATION_MODEL=
COMMUNICATION_API_KEY=
COMMUNICATION_BASE_URL=
COMMUNICATION_USE_LLM=true
COMMUNICATION_MIN_CONFIDENCE=0.45
COMMUNICATION_CORE_CONFIDENCE=0.85
COMMUNICATION_OUTPUT_OBSIDIAN=true
COMMUNICATION_MAX_RAW_ENTRIES=150
COMMUNICATION_MAX_SAMPLES=300
COMMUNICATION_MAX_PATTERNS=100

# Response Inference Engine
# Fidelity-first response layer untuk Brain Chat. Jika provider kosong, fallback ke
# COMMUNICATION_*, IDENTITY_*, BRAIN_CHAT_*, lalu LLM_*.
RESPONSE_INFERENCE_ENABLED=true
RESPONSE_INFERENCE_PROVIDER=
RESPONSE_INFERENCE_MODEL=
RESPONSE_INFERENCE_API_KEY=
RESPONSE_INFERENCE_BASE_URL=
RESPONSE_INFERENCE_USE_LLM=true
RESPONSE_INFERENCE_LOGS_ENABLED=true
RESPONSE_INFERENCE_MIN_CONFIDENCE=0.55
RESPONSE_INFERENCE_MAX_OVERCLAIM_RISK=0.30
RESPONSE_INFERENCE_OUTPUT_OBSIDIAN=false

# Owner Answer Calibration
# Ground truth jawaban asli pemilik diary untuk mengukur dan mengkalibrasi
# Response Inference Engine. Jika provider kosong, fallback ke
# RESPONSE_INFERENCE_*, COMMUNICATION_*, IDENTITY_*, BRAIN_CHAT_*, lalu LLM_*.
OWNER_CALIBRATION_ENABLED=true
OWNER_CALIBRATION_PROVIDER=
OWNER_CALIBRATION_MODEL=
OWNER_CALIBRATION_API_KEY=
OWNER_CALIBRATION_BASE_URL=
OWNER_CALIBRATION_USE_LLM_JUDGE=false
OWNER_CALIBRATION_MIN_PASS_SCORE=0.75
OWNER_CALIBRATION_OUTPUT_OBSIDIAN=true
OWNER_CALIBRATION_MAX_EXAMPLES=100
OWNER_CALIBRATION_APPLY_HINTS=true

# Chat Sample Importer
# Evidence gaya chat asli owner. Hanya pesan owner yang menjadi style evidence.
CHAT_SAMPLE_IMPORT_ENABLED=true
CHAT_SAMPLE_DIR=../AhyarBrainVault/85_Chat_Samples
CHAT_SAMPLE_OWNER_ALIASES=Ahyar,Kukuh,Ahyar Pattani,owner,me,saya
CHAT_SAMPLE_OUTPUT_OBSIDIAN=true
CHAT_SAMPLE_AUTO_CREATE_OWNER_EXAMPLES=true
CHAT_SAMPLE_MAX_FILES=50
CHAT_SAMPLE_MAX_MESSAGES_PER_FILE=5000
CHAT_SAMPLE_DEDUP_BY_HASH=true
CHAT_SAMPLE_REVIEW_SENSITIVE=true

# Similarity Evaluation Loop
# Jika provider kosong, fallback ke OWNER_CALIBRATION_*, RESPONSE_INFERENCE_*,
# COMMUNICATION_*, IDENTITY_*, BRAIN_CHAT_*, lalu LLM_*.
SIMILARITY_EVAL_ENABLED=true
SIMILARITY_EVAL_PROVIDER=
SIMILARITY_EVAL_MODEL=
SIMILARITY_EVAL_API_KEY=
SIMILARITY_EVAL_BASE_URL=
SIMILARITY_EVAL_USE_LLM_JUDGE=false
SIMILARITY_EVAL_MIN_PASS_SCORE=0.75
SIMILARITY_EVAL_MIN_OVERALL_SCORE=0.75
SIMILARITY_EVAL_MAX_TOO_AI_SCORE=0.25
SIMILARITY_EVAL_MAX_OVERCLAIM_RISK=0.30
SIMILARITY_EVAL_MAX_UNDERFIT_RISK=0.35
SIMILARITY_EVAL_REGRESSION_THRESHOLD=0.10
SIMILARITY_EVAL_OUTPUT_OBSIDIAN=true
SIMILARITY_EVAL_MAX_CASES=100

# Drift Control / Anti-Overclaim Guard
# Guard final answer agar tidak overclaim, AI-like, debug/source leak, atau drift.
DRIFT_CONTROL_ENABLED=true
DRIFT_CONTROL_PROVIDER=
DRIFT_CONTROL_MODEL=
DRIFT_CONTROL_API_KEY=
DRIFT_CONTROL_BASE_URL=
DRIFT_CONTROL_USE_LLM_JUDGE=false
DRIFT_CONTROL_MAX_OVERCLAIM_SCORE=0.30
DRIFT_CONTROL_MAX_TOO_AI_SCORE=0.25
DRIFT_CONTROL_MAX_STYLE_DRIFT_SCORE=0.35
DRIFT_CONTROL_MAX_UNSUPPORTED_CLAIM_SCORE=0.30
DRIFT_CONTROL_BLOCK_CRITICAL=true
DRIFT_CONTROL_REWRITE_ENABLED=true
DRIFT_CONTROL_OUTPUT_OBSIDIAN=true

# Self-Reflection Memory Evolution
# Refleksi berkala evidence-bound: apa arti data baru terhadap model diri owner.
# Menghasilkan reflection logs, evolution suggestions (proposal, BUKAN auto-apply),
# dan entity snapshots. Jika provider kosong, fallback ke DRIFT_CONTROL_*,
# SIMILARITY_EVAL_*, OWNER_CALIBRATION_*, RESPONSE_INFERENCE_*, COMMUNICATION_*,
# IDENTITY_*, BRAIN_CHAT_*, lalu LLM_*.
SELF_REFLECTION_ENABLED=true
SELF_REFLECTION_PROVIDER=
SELF_REFLECTION_MODEL=
SELF_REFLECTION_API_KEY=
SELF_REFLECTION_BASE_URL=
SELF_REFLECTION_USE_LLM=true
SELF_REFLECTION_OUTPUT_OBSIDIAN=true
SELF_REFLECTION_MAX_RAW_ENTRIES=100
SELF_REFLECTION_MAX_IDENTITY_FACTS=200
SELF_REFLECTION_MAX_COMMUNICATION_PATTERNS=100
SELF_REFLECTION_MAX_REPORTS=20
SELF_REFLECTION_MAX_DRIFT_LOGS=50
SELF_REFLECTION_MAX_SIMILARITY_RESULTS=50
SELF_REFLECTION_MIN_EVIDENCE_FOR_SUGGESTION=2
SELF_REFLECTION_AUTO_APPLY=false

# Identity Conflict & Contradiction Resolver
# Menyimpan tension/kontradiksi owner tanpa menghapus salah satu sisi evidence.
IDENTITY_CONFLICTS_ENABLED=true
IDENTITY_CONFLICTS_PROVIDER=
IDENTITY_CONFLICTS_MODEL=
IDENTITY_CONFLICTS_API_KEY=
IDENTITY_CONFLICTS_BASE_URL=
IDENTITY_CONFLICTS_USE_LLM=true
IDENTITY_CONFLICTS_OUTPUT_OBSIDIAN=true
IDENTITY_CONFLICTS_MIN_CONFIDENCE=0.55
IDENTITY_CONFLICTS_MIN_SEVERITY=low
IDENTITY_CONFLICTS_MAX_IDENTITY_FACTS=200
IDENTITY_CONFLICTS_MAX_REFLECTIONS=50
IDENTITY_CONFLICTS_MAX_RAW_ENTRIES=100
IDENTITY_CONFLICTS_AUTO_RESOLVE=false

# Final Self-Clone Evaluation Suite
# Evaluasi final read-only untuk readiness self-clone. Tidak auto-edit brain data.
SELF_CLONE_EVAL_ENABLED=true
SELF_CLONE_EVAL_PROVIDER=
SELF_CLONE_EVAL_MODEL=
SELF_CLONE_EVAL_API_KEY=
SELF_CLONE_EVAL_BASE_URL=
SELF_CLONE_EVAL_USE_LLM_JUDGE=false
SELF_CLONE_EVAL_OUTPUT_OBSIDIAN=true
SELF_CLONE_EVAL_MAX_CASES=200
SELF_CLONE_EVAL_MIN_PASS_SCORE=0.75
SELF_CLONE_EVAL_RELEASE_MIN_SCORE=0.85
SELF_CLONE_EVAL_MAX_TOO_AI_SCORE=0.25
SELF_CLONE_EVAL_MAX_OVERCLAIM_RISK=0.30
SELF_CLONE_EVAL_MAX_PRIVATE_LEAK_RISK=0.15
SELF_CLONE_EVAL_FAIL_ON_CRITICAL=true

# Safe Entity Runtime / Read-Only Autonomy Boundary
# Runtime boleh membaca brain dan membuat proposal, tetapi tidak menjalankan aksi eksternal.
SAFE_ENTITY_RUNTIME_ENABLED=true
ENTITY_RUNTIME_MODE=read_only
ENTITY_RUNTIME_PROVIDER=
ENTITY_RUNTIME_MODEL=
ENTITY_RUNTIME_API_KEY=
ENTITY_RUNTIME_BASE_URL=
ENTITY_RUNTIME_USE_LLM=true
ENTITY_RUNTIME_OUTPUT_OBSIDIAN=true
ENTITY_RUNTIME_ALLOW_EXTERNAL_ACTIONS=false
ENTITY_RUNTIME_ALLOW_IDENTITY_MUTATION=false
ENTITY_RUNTIME_ALLOW_COMMUNICATION_MUTATION=false
ENTITY_RUNTIME_ALLOW_FILE_WRITE=false
ENTITY_RUNTIME_ALLOW_COMMAND_EXECUTION=false
ENTITY_RUNTIME_ALLOW_PROPOSALS=true
ENTITY_RUNTIME_REQUIRE_APPROVAL_FOR_ALL_ACTIONS=true
ENTITY_RUNTIME_MAX_RISK_SCORE=0.30
ENTITY_RUNTIME_BLOCK_EXTERNAL_ACTIONS=true
BRAIN_ROUTINE_RUN_ENTITY_AUDIT=true

# Long-Term Memory Consolidation
# Membuat memory jangka panjang dan review queue tanpa menghapus raw data.
LONG_TERM_MEMORY_ENABLED=true
MEMORY_CONSOLIDATION_PROVIDER=
MEMORY_CONSOLIDATION_MODEL=
MEMORY_CONSOLIDATION_API_KEY=
MEMORY_CONSOLIDATION_BASE_URL=
MEMORY_CONSOLIDATION_USE_LLM=true
MEMORY_CONSOLIDATION_OUTPUT_OBSIDIAN=true
MEMORY_CONSOLIDATION_AUTO_ARCHIVE=false
MEMORY_CONSOLIDATION_AUTO_MERGE=false
MEMORY_CONSOLIDATION_MIN_CONFIDENCE=0.55
MEMORY_CONSOLIDATION_CORE_CONFIDENCE=0.85
MEMORY_CONSOLIDATION_MAX_RAW_ENTRIES=300
MEMORY_CONSOLIDATION_MAX_AGENT_MEMORIES=300
MEMORY_CONSOLIDATION_MAX_IDENTITY_FACTS=200
MEMORY_CONSOLIDATION_MAX_CHAT_MESSAGES=500
MEMORY_CONSOLIDATION_STALE_DAYS=180
MEMORY_CONSOLIDATION_REVIEW_REQUIRED=true
BRAIN_ROUTINE_RUN_MEMORY_CONSOLIDATION=false
BRAIN_ROUTINE_RUN_RELEASE_AUDIT=false

FINAL_RELEASE_ENABLED=true
FINAL_RELEASE_VERSION=1.0.0
FINAL_RELEASE_OUTPUT_OBSIDIAN=true
FINAL_RELEASE_REQUIRE_BACKUP=true
FINAL_RELEASE_REQUIRE_BUILD=true
FINAL_RELEASE_REQUIRE_SECRET_SCAN=true
FINAL_RELEASE_REQUIRE_SELF_CLONE_EVAL=true
FINAL_RELEASE_REQUIRE_RUNTIME_BOUNDARY=true
FINAL_RELEASE_REQUIRE_LONG_TERM_MEMORY=true
FINAL_RELEASE_MIN_OVERALL_SCORE=0.85
FINAL_RELEASE_BLOCK_ON_CRITICAL=true
FINAL_RELEASE_ALLOW_WARNINGS=true

# Semantic Memory Index + Vector Search
EMBEDDING_PROVIDER=openai
EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_API_KEY=
EMBEDDING_BASE_URL=
EMBEDDING_DIMENSIONS=1536
BRAIN_INDEX_LIMIT=25
BRAIN_INDEX_FORCE=false

# Attachment & File Ingestion MVP
ATTACHMENT_IMPORT_DIR=80_Attachments
ATTACHMENT_IMPORT_LIMIT=5
ATTACHMENT_MAX_FILE_SIZE_MB=20
ATTACHMENT_VISION_ENABLED=false
ATTACHMENT_PDF_ENABLED=true
ATTACHMENT_DOCX_ENABLED=true
ATTACHMENT_IMAGE_ENABLED=true

# Obsidian Vault Importer
OBSIDIAN_VAULT_PATH=../AhyarBrainVault
OBSIDIAN_DIARY_DIR=00_Diary
OBSIDIAN_IMPORT_LIMIT=5
OBSIDIAN_FAILED_RETRY_COOLDOWN_MS=300000
OBSIDIAN_SYNC_ENABLED=true
OBSIDIAN_SYNC_LIMIT=100
OBSIDIAN_SYNC_DRY_RUN=false
OBSIDIAN_SYNC_WRITE_INDEXES=true
OBSIDIAN_SYNC_INCLUDE_LOW_CONFIDENCE=true
# Opsional. Jika kosong, importer memakai user login atau user_id raw_entries terbaru.
# OBSIDIAN_USER_ID=YOUR_SUPABASE_USER_ID
