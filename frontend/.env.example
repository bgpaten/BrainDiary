# Opsional: set "true" untuk memakai data graph fallback dev (TANPA Supabase).
# Default kosong/false. Hanya untuk mengembangkan tampilan saat DB belum siap.
VITE_USE_DEV_FALLBACK=

# Brain Engine trigger:
# - edge_function: panggil Supabase Edge Function process-brain-entry
# - local_worker: panggil endpoint dev Vite yang menjalankan npm run brain:worker
VITE_BRAIN_ENGINE_TRIGGER=local_worker
VITE_OBSIDIAN_IMPORTER_ENABLED=true
VITE_ATTACHMENT_IMPORTER_ENABLED=true
VITE_BRAIN_INDEXER_ENABLED=true
VITE_OBSIDIAN_SYNC_ENABLED=true
VITE_BRAIN_DIGEST_ENABLED=true
VITE_BRAIN_ROUTINE_ENABLED=true
VITE_BRAIN_BACKUP_ENABLED=true
VITE_CHAT_SAMPLE_IMPORT_ENABLED=true
VITE_FINAL_RELEASE_ENABLED=true
