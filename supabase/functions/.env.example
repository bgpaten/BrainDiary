# =============================================================================
# Secrets untuk Edge Function "process-brain-entry".
# JANGAN commit nilai asli. Set ke Supabase dengan:
#   supabase secrets set --env-file supabase/functions/.env
# (atau satu per satu: supabase secrets set LLM_API_KEY=...)
#
# Catatan: SUPABASE_URL, SUPABASE_ANON_KEY, SUPABASE_SERVICE_ROLE_KEY otomatis
# tersedia di runtime Edge Function - tidak perlu di-set manual untuk deploy.
# Saat menjalankan `supabase functions serve` secara lokal, baru perlu disetel.
# =============================================================================

# --- Konfigurasi LLM (model-agnostic) ---------------------------------------
# Protokol: "anthropic" (default) atau "openai".
LLM_PROTOCOL=anthropic

# Format Claude Code / FreeModel.
ANTHROPIC_API_KEY=YOUR_API_KEY
ANTHROPIC_BASE_URL=https://cc.freemodel.dev
CLAUDE_CODE_DISABLE_NONESSENTIAL_TRAFFIC=1

# Opsional. Jika kosong, function memakai fallback Anthropic-compatible default.
# ANTHROPIC_MODEL=claude-sonnet-4-20250514

# Alternatif generic (dipakai lebih dulu jika diset):
# LLM_API_KEY=YOUR_API_KEY
# LLM_BASE_URL=https://cc.freemodel.dev
# LLM_MODEL=claude-sonnet-4-20250514

# --- Hanya untuk `supabase functions serve` lokal ---------------------------
# SUPABASE_URL=http://127.0.0.1:54321
# SUPABASE_ANON_KEY=your-local-anon-key
# SUPABASE_SERVICE_ROLE_KEY=your-local-service-role-key
